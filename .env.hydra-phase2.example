# Phase 2 knowledge-store environment — copy to .env.hydra-phase2 and fill in.
# The real file is gitignored. DO NOT commit credentials.
#
# When this file is sourced (e.g. `set -a; source .env.hydra-phase2; set +a`),
# Hydra's state adapters switch from local JSON to DynamoDB + S3.
#
# See INSTALL.md "Phase 2 — cloud knowledge store (optional)" for the full
# provisioning walkthrough.

# --- Backend mode ----------------------------------------------------------
# Flip from "local" (default) to "dynamodb" to route state reads/writes
# through DynamoDB via scripts/state-{get,put}.sh.
HYDRA_STATE_BACKEND=dynamodb

# Dual-mode memory: sync ./memory/ <-> s3://$HYDRA_S3_BUCKET/$HYDRA_S3_PREFIX/memory/
# via `aws s3 sync` (scripts/hydra-memory-sync.sh). Orthogonal to the state
# adapter above.
#   local       = default, Phase 1; no S3 calls
#   s3          = pull at session start; push after memory writes; fail-soft
#   s3-strict   = same as s3, but boot refuses on pull failure (cloud commander)
# Spec: docs/specs/2026-04-17-dual-mode-memory.md
HYDRA_MEMORY_BACKEND=s3

# --- AWS targeting ---------------------------------------------------------
# NEVER hardcoded in source — always env. Set per-operator.
HYDRA_AWS_REGION=REPLACE_WITH_YOUR_REGION            # e.g. us-east-1
# HYDRA_AWS_ENDPOINT_URL is only for localstack tests; leave unset in prod.
# HYDRA_AWS_ENDPOINT_URL=

# --- S3 knowledge store ----------------------------------------------------
# The bucket you provisioned for memory/ + logs/.
HYDRA_S3_BUCKET=REPLACE_WITH_YOUR_BUCKET_NAME
# The per-instance prefix inside the bucket. Pick a stable id — "prod",
# "dev", "gary-laptop", etc. Isolation is per-prefix, not per-bucket.
HYDRA_S3_PREFIX=REPLACE_WITH_INSTANCE_ID
# Local mountpoint. mount-s3 will mount the bucket+prefix here.
HYDRA_EXTERNAL_MEMORY_DIR=${HOME}/.hydra/memory

# Extra mount-s3 flags (optional). Defaults are sane.
# HYDRA_S3_MOUNT_OPTS="--allow-overwrite --file-mode 0644 --dir-mode 0755"

# --- DynamoDB table names --------------------------------------------------
# Default naming is "commander-<key>"; override if your org namespaces them.
# HYDRA_DDB_TABLE_ACTIVE=commander-active
# HYDRA_DDB_TABLE_BUDGET=commander-budget
# HYDRA_DDB_TABLE_MEMORY_CITATIONS=commander-memory-citations

# Partition key — Hydra stores one row per logical blob. Defaults below work.
# HYDRA_DDB_PK=id
# HYDRA_DDB_PK_VALUE=singleton
