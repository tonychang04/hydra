{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Template for the commander's permission profile. Copy to .claude/settings.local.json and replace $COMMANDER_ROOT with your absolute path. Replace $HOME_DIR with your home directory. The deny list for self-modification is critical — do not relax it.",
  "permissions": {
    "allow": [
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh repo view *)",
      "Bash(gh auth status)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git worktree *)",
      "Bash(ls *)",
      "Bash(cat commander/*)",
      "Bash(touch commander/PAUSE)",
      "Bash(rm commander/PAUSE)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(docker exec *)",
      "Bash(docker inspect *)",
      "Bash(docker stop *)",
      "Bash(docker rm *)",
      "Bash(curl -sf http://localhost:*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl -s http://localhost:*)",
      "Read($COMMANDER_ROOT/**)",
      "Read($COMMANDER_ROOT/../**)",
      "Read(**/.env.example)",
      "Read(**/.env.template)",
      "Read(**/env.example)",
      "Read(**/env.template)",
      "Write($COMMANDER_ROOT/logs/**)",
      "Write($COMMANDER_ROOT/state/**)",
      "Write($COMMANDER_ROOT/memory/**)",
      "Edit($COMMANDER_ROOT/state/**)",
      "Edit($COMMANDER_ROOT/logs/**)",
      "Edit($COMMANDER_ROOT/memory/**)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME_DIR/*)",
      "Bash(sudo *)",
      "Bash(curl file://*)",
      "Bash(wget *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(gh pr merge *)",
      "Bash(docker system prune *)",
      "Bash(docker rm -f *)",
      "Bash(docker volume rm *)",
      "Read($HOME_DIR/.ssh/**)",
      "Read($HOME_DIR/.aws/**)",
      "Read($HOME_DIR/.config/**)",
      "Read($HOME_DIR/Library/**)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/.env.development)",
      "Read(**/secrets/**)",
      "Read(**/credentials*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Write($COMMANDER_ROOT/CLAUDE.md)",
      "Write($COMMANDER_ROOT/policy.md)",
      "Write($COMMANDER_ROOT/budget.json)",
      "Write($COMMANDER_ROOT/.claude/**)",
      "Edit($COMMANDER_ROOT/CLAUDE.md)",
      "Edit($COMMANDER_ROOT/policy.md)",
      "Edit($COMMANDER_ROOT/budget.json)",
      "Edit($COMMANDER_ROOT/.claude/**)"
    ]
  }
}
