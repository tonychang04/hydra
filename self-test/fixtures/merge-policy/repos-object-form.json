      "merge_policy": {
        "T1": "human",
        "T2": "human",
        "T3": "never"
      }
    },
    {
      "owner": "fixture-org",
      "name": "team-repo",
      "local_path": "/fixture/team-repo",
      "enabled": true,
      "ticket_trigger": "assignee",
      "merge_policy": {
        "T1": "auto",
        "T2": "auto_if_review_clean"
      }
    },
    {
      "owner": "fixture-org",
      "name": "default-repo",
      "local_path": "/fixture/default-repo",
      "enabled": true,
      "ticket_trigger": "assignee"
    }
  ]
