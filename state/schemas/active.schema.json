{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hydra/state/schemas/active.schema.json",
  "title": "Hydra active workers state",
  "description": "Runtime state of in-flight workers. Commander writes this after each spawn and on each worker completion. See CLAUDE.md 'Operating loop' step 6 (Track) — worker entries MUST carry {id, ticket, repo, tier, started_at, subagent_type, status}.",
  "type": "object",
  "additionalProperties": true,
  "required": ["workers"],
  "properties": {
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "ticket", "repo", "tier", "started_at", "subagent_type", "status"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable worker id used by Agent / SendMessage / TaskStop.",
            "minLength": 1
          },
          "ticket": {
            "type": "string",
            "description": "Ticket reference (e.g. 'owner/repo#42', 'LIN-123').",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "description": "Repo slug (owner/name) or the local_path from state/repos.json.",
            "minLength": 1
          },
          "tier": {
            "type": "string",
            "enum": ["T1", "T2", "T3"],
            "description": "Risk tier per policy.md."
          },
          "started_at": {
            "type": "string",
            "description": "ISO-8601 timestamp when the worker was spawned.",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}"
          },
          "subagent_type": {
            "type": "string",
            "enum": ["worker-implementation", "worker-review", "worker-test-discovery"]
          },
          "status": {
            "type": "string",
            "enum": ["running", "paused", "stuck", "done", "failed"]
          }
        }
      }
    },
    "last_updated": {
      "type": ["string", "null"],
      "description": "ISO-8601 timestamp of the most recent write, or null if never touched."
    }
  }
}
