{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hydra/state/schemas/budget-used.schema.json",
  "title": "Hydra daily budget counters",
  "description": "Per-day tallies that the preflight check reads against budget.json caps. Reset when 'date' rolls over.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "date",
    "tickets_completed_today",
    "tickets_failed_today",
    "total_worker_wall_clock_minutes_today",
    "rate_limit_hits_today"
  ],
  "properties": {
    "date": {
      "type": ["string", "null"],
      "description": "ISO date (YYYY-MM-DD) these counters apply to; null before the first write.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "tickets_completed_today": {
      "type": "integer",
      "minimum": 0
    },
    "tickets_failed_today": {
      "type": "integer",
      "minimum": 0
    },
    "total_worker_wall_clock_minutes_today": {
      "type": "number",
      "minimum": 0
    },
    "rate_limit_hits_today": {
      "type": "integer",
      "minimum": 0
    },
    "phase2_spend_usd_today": {
      "type": "number",
      "minimum": 0,
      "description": "Ignored in Phase 1. Populated in Phase 2 when commander runs against the Anthropic API."
    }
  }
}
